# =============================================================================
# Aurelia – Docker Compose environment TEMPLATE
#
# This file is COMMITTED to git. NEVER put real secrets here.
# Real values live in `.env` (which is gitignored).
#
# Quick start (recommended):
#   node scripts/generate-secrets.js --write
#     → creates a strong .env automatically
#
# Or manually:
#   1) cp docker.env.example .env
#   2) Replace every <PLACEHOLDER> below with a strong, unique secret
#   3) docker compose up --build
# =============================================================================

# ── REQUIRED SECRETS (replace every <PLACEHOLDER>) ───────────────────────────

# SQL Server SA password.
# Rules: 16+ chars, mix of upper/lower/digit/symbol. Avoid $ ' " ` \ for shell safety.
DB_SA_PASSWORD=<REPLACE_WITH_STRONG_PASSWORD_MIN_16_CHARS>

# JWT signing secret — used to sign auth tokens. Treat like a private key.
# Rules: 64+ random characters (hex recommended).
JWT_SECRET=<REPLACE_WITH_64_CHAR_RANDOM_HEX>

# Initial admin account created by the seed script.
# CHANGE these for any non-throwaway environment.
SEED_ADMIN_EMAIL=admin@aurelia.local
SEED_ADMIN_PASSWORD=<REPLACE_WITH_STRONG_PASSWORD_MIN_16_CHARS>

# ── OPTIONAL (safe defaults already set in docker-compose.yml) ───────────────

# JWT_EXPIRES_IN=7d
# BCRYPT_ROUNDS=10
# MAX_UPLOAD_MB=5

# Override the backend API URL baked into the Next.js build.
# Default (localhost) is correct when running Docker on your own machine.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:5001/api

# Internal proxy target used by Next.js rewrites for /api/* on port 3000.
# NEXT_SERVER_API_PROXY_TARGET=http://backend:5001

# Extra CORS origins (comma-separated). Rarely needed locally.
# ALLOWED_ORIGINS=

# Cloudinary (leave blank to use local disk storage for uploads)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
