// Aurelia Hotel - Prisma schema
// SQL Server provider does not support native enums, so status/role/category
// are stored as strings and validated in zod at the API boundary.

generator client { 
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(cuid())
  name              String
  email             String             @unique
  password          String
  role              String             @default("GUEST") // GUEST | ADMIN | MANAGER | STAFF | CONCIERGE
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  bookings          Booking[]
  conciergeRequests ConciergeRequest[]
  auditLogs         AuditLog[]
}

model Room {
  id           String             @id @default(cuid())
  title        String
  slug         String             @unique
  description  String             @db.NVarChar(Max)
  price        Decimal            @db.Decimal(10, 2)
  capacity     Int
  images       String             @db.NVarChar(Max) // JSON-encoded string array
  amenities    String             @db.NVarChar(Max) // JSON-encoded string array
  active       Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  bookings     Booking[]
  pricingRules PricingRule[]
  inventory    RoomInventoryDay[]
  bookingRooms BookingRoom[]

  @@index([active])
}

model Booking {
  id             String             @id @default(cuid())
  guestName      String
  guestEmail     String
  guestPhone     String?
  notes          String?            @db.NVarChar(Max)

  userId         String?
  roomId         String
  checkIn        DateTime
  checkOut       DateTime
  guests         Int
  totalPrice     Decimal            @db.Decimal(10, 2)
  status         String             @default("PENDING") // PENDING | CONFIRMED | CANCELLED | COMPLETED
  paymentStatus  String             @default("UNPAID") // UNPAID | PARTIAL | PAID | REFUNDED | FAILED
  source         String             @default("WEB") // WEB | ADMIN | CONCIERGE

  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  // NoAction on User to avoid SQL Server's "multiple cascade paths" error
  user User? @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  room Room  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  bookingRooms BookingRoom[]
  payments     Payment[]
  conciergeRequests ConciergeRequest[]
  auditLogs    AuditLog[]

  @@index([roomId, checkIn, checkOut, status])
  @@index([guestEmail])
  @@index([status])
  @@index([paymentStatus])
}

model BookingRoom {
  id          String   @id @default(cuid())
  bookingId   String
  roomId      String
  checkIn     DateTime
  checkOut    DateTime
  guests      Int
  nightlyRate Decimal  @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  room    Room    @relation(fields: [roomId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([bookingId])
  @@index([roomId, checkIn, checkOut])
}

model PricingRule {
  id             String    @id @default(cuid())
  name           String
  roomId         String?
  strategy       String    // WEEKEND | SEASONAL | SURGE | PROMO
  adjustmentType String    @default("PERCENT") // PERCENT | FLAT
  adjustment     Decimal   @db.Decimal(10, 2)
  priority       Int       @default(100)
  active         Boolean   @default(true)
  startsAt       DateTime
  endsAt         DateTime
  daysOfWeek     String?   @db.NVarChar(Max) // JSON array of weekday numbers 0-6
  minNights      Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  room Room? @relation(fields: [roomId], references: [id], onDelete: SetNull)

  @@index([roomId, active, startsAt, endsAt])
  @@index([strategy, active])
}

model RoomInventoryDay {
  id             String   @id @default(cuid())
  roomId         String
  date           DateTime
  blocked        Boolean  @default(false)
  maxOccupancy   Int?
  overridePrice  Decimal? @db.Decimal(10, 2)
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, date])
  @@index([date, blocked])
}

model Payment {
  id                String   @id @default(cuid())
  bookingId         String
  provider          String   // STRIPE | RAZORPAY | MANUAL
  providerPaymentId String?
  amount            Decimal  @db.Decimal(10, 2)
  currency          String   @default("USD")
  status            String   // PENDING | SUCCEEDED | FAILED | REFUNDED
  paidAt            DateTime?
  metadata          String?  @db.NVarChar(Max)
  createdAt         DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, status])
}

model ConciergeRequest {
  id          String   @id @default(cuid())
  bookingId   String?
  userId      String?
  guestName   String
  guestEmail  String
  type        String   // AIRPORT_PICKUP | SPA | DINNER | EARLY_CHECKIN | CITY_TOUR
  details     String   @db.NVarChar(Max)
  status      String   @default("OPEN") // OPEN | IN_PROGRESS | COMPLETED | CANCELLED
  assignedTo  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([bookingId])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String
  before      String?  @db.NVarChar(Max)
  after       String?  @db.NVarChar(Max)
  metadata    String?  @db.NVarChar(Max)
  bookingId   String?
  createdAt   DateTime @default(now())

  actorUser User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorUserId, createdAt])
}

model NotificationEvent {
  id          String   @id @default(cuid())
  channel     String   // IN_APP | EMAIL | SMS | WEBHOOK
  type        String   // BOOKING_CREATED | BOOKING_CANCELLED | PAYMENT_RECEIVED | INQUIRY_CREATED
  status      String   @default("PENDING") // PENDING | SENT | FAILED
  recipient   String?
  payload     String   @db.NVarChar(Max)
  processedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([status, createdAt])
  @@index([type])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  image     String
  rating    Int
  message   String   @db.NVarChar(Max)
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([approved])
}

model Gallery {
  id        String   @id @default(cuid())
  imageUrl  String
  category  String  // ROOMS | RESTAURANT | SPA | EVENTS | EXTERIOR | LIFESTYLE
  caption   String?
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([category])
}

model ContactInquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String   @db.NVarChar(Max)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read])
  @@index([createdAt])
}
