# --- Aurelia backend env (TEMPLATE — committed to git) ---
# ⚠️  NEVER COMMIT YOUR REAL .env FILE — it is gitignored for a reason.
# ⚠️  Replace EVERY <PLACEHOLDER> with a strong, unique value.
#
# Recommended: from the repo root, run
#   node scripts/generate-secrets.js --write
# That writes a strong root .env for docker-compose. For local backend dev
# (running outside Docker), copy this file to backend/.env and fill in values.

NODE_ENV=development
PORT=5001

# SQL Server connection
# When running inside docker-compose:
DATABASE_URL="sqlserver://sqlserver:1433;database=LuxuryHotelDB;user=sa;password=<DB_SA_PASSWORD>;trustServerCertificate=true"
# Local Windows SQL Express alternative:
# DATABASE_URL="sqlserver://localhost:44340;database=LuxuryHotelDB;integratedSecurity=true;trustServerCertificate=true"

# Auth — must be 64+ random chars. Generate with: node scripts/generate-secrets.js
JWT_SECRET="<REPLACE_WITH_64_CHAR_RANDOM_HEX>"
JWT_EXPIRES_IN="7d"
BCRYPT_ROUNDS=10

# CORS
FRONTEND_URL="http://localhost:3000"
ALLOWED_ORIGINS=""

# Uploads — leave Cloudinary blank to use local /uploads disk storage
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
MAX_UPLOAD_MB=5
# PUBLIC_BASE_URL=http://localhost:5001

# Seeded admin (used by `npm run prisma:seed`). No default — must be set explicitly.
SEED_ADMIN_EMAIL=admin@aurelia.local
SEED_ADMIN_PASSWORD=<REPLACE_WITH_STRONG_PASSWORD_MIN_16_CHARS>

# --- Database Setup (only used when running scripts that talk to sqlserver directly) ---
DB_SA_PASSWORD="<REPLACE_WITH_STRONG_PASSWORD_MIN_16_CHARS>"
DB_HOST="sqlserver"
DB_PORT="1433"
DB_NAME="LuxuryHotelDB"
DB_USER="sa"
