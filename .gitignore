# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules
**/node_modules

# ── Build output ─────────────────────────────────────────────────────────────
.next
**/.next
dist
**/dist
build
**/build

# ── Environment variables (NEVER commit) ─────────────────────────────────────
.env
.env.*
!.env.example
!docker.env.example
**/.env
**/.env.*
!**/.env.example

# ── Logs ─────────────────────────────────────────────────────────────────────
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ──────────────────────────────────────────────────────────────────────
.vscode
.idea
*.swp

# ── Coverage / tests ─────────────────────────────────────────────────────────
coverage
.nyc_output

# ── Prisma generated ─────────────────────────────────────────────────────────
generated
**/generated

# ── Uploads (runtime user content — never check in) ──────────────────────────
backend/uploads/*
!backend/uploads/.gitkeep

# ── Terraform / IaC state ────────────────────────────────────────────────────
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl

# ── Docker runtime data ──────────────────────────────────────────────────────
docker-data/

# ── Secrets / keys (defense in depth) ────────────────────────────────────────
*.pem
*.key
*.pfx
*.p12
secrets/